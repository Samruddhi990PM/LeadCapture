{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/submit-lead", "dest": "/api/submit-lead.py" },
    { "src": "/api/get-leads",   "dest": "/api/get-leads.py"   },
    { "src": "/dashboard",       "dest": "/public/dashboard.html" },
    { "src": "/dashboard.html",  "dest": "/public/dashboard.html" },
    { "src": "/(.*)",            "dest": "/public/$1" }
  ]
}
