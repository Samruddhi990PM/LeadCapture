{
  "version": 2,
  "builds": [
    { "src": "api/leads.py", "use": "@vercel/python" },
    { "src": "public/**",    "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/leads",      "dest": "/api/leads.py" },
    { "src": "/dashboard",      "dest": "/public/dashboard.html" },
    { "src": "/dashboard.html", "dest": "/public/dashboard.html" },
    { "src": "/(.*)",           "dest": "/public/$1" }
  ]
}
